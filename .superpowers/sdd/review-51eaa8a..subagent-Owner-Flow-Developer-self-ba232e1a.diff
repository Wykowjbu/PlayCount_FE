me="p-5 border-t border-[var(--pc-hairline)] bg-[var(--pc-canvas)] flex justify-end gap-3"> +                  <button +                    type="button" +                    onClick={() => setShowAddCourtModal(false)} +                    className="text-xs font-semibold px-4 py-2 rounded-md border border-[var(--pc-hairline)] bg-white text-[var(--pc-ink)] hover:bg-[var(--pc-hairline-soft)] active:scale-[0.98] transition-all cursor-pointer" +                  > +                    Hủy +                  </button> +                  <Button +                    type="submit" +                    variant="CommitPrimary" +                    className="text-xs font-bold" +                  > +                    Thêm sân +                  </Button> +                </div> +              </form> + +            </div> +          </div> +        )} + +      </div> +    </Tooltip.Provider> +  ); +} diff --git a/src/lib/pricing-utils.ts b/src/lib/pricing-utils.ts new file mode 100644 index 0000000..aeed18b --- /dev/null +++ b/src/lib/pricing-utils.ts @@ -0,0 +1,44 @@ +﻿export interface PricingRule { +  id: string; +  name: string; +  daysOfWeek: number[]; // 1 = Thứ 2, ..., 7 = Chủ Nhật +  startTime: string; // "HH:MM" +  endTime: string; // "HH:MM" +  price: number; +  priority: number; +} + +function parseTimeToMinutes(timeStr: string): number { +  const [h, m] = timeStr.split(':').map(Number); +  return h * 60 + m; +} + +export function checkPricingRulesOverlap(rules: PricingRule[]): string[] { +  const overlappingIds = new Set<string>(); +   +  for (let i = 0; i < rules.length; i++) { +    const ruleA = rules[i]; +    const startA = parseTimeToMinutes(ruleA.startTime); +    const endA = parseTimeToMinutes(ruleA.endTime); +     +    for (let j = i + 1; j < rules.length; j++) { +      const ruleB = rules[j]; +       +      // Check for common days +      const hasCommonDay = ruleA.daysOfWeek.some(day => ruleB.daysOfWeek.includes(day)); +      if (!hasCommonDay) continue; +       +      const startB = parseTimeToMinutes(ruleB.startTime); +      const endB = parseTimeToMinutes(ruleB.endTime); +       +      // Check for overlapping intervals +      const hasOverlap = startA < endB && startB < endA; +      if (hasOverlap) { +        overlappingIds.add(ruleA.id); +        overlappingIds.add(ruleB.id); +      } +    } +  } +   +  return Array.from(overlappingIds); +} diff --git a/tests/pricing-rules.test.tsx b/tests/pricing-rules.test.tsx new file mode 100644 index 0000000..20f0280 --- /dev/null +++ b/tests/pricing-rules.test.tsx @@ -0,0 +1,80 @@ +﻿import { checkPricingRulesOverlap, PricingRule } from '@/lib/pricing-utils'; + +describe('Pricing Rules Overlap Check Utility', () => { +  const sampleRules: PricingRule[] = [ +    { +      id: 'rule-1', +      name: 'Giờ cao điểm Thứ 2', +      daysOfWeek: [1], // Thứ 2 +      startTime: '17:00', +      endTime: '20:00', +      price: 250000, +      priority: 1, +    }, +    { +      id: 'rule-2', +      name: 'Giờ thường Thứ 2', +      daysOfWeek: [1], // Thứ 2 +      startTime: '08:00', +      endTime: '17:00', +      price: 150000, +      priority: 1, +    }, +    { +      id: 'rule-3', +      name: 'Khung giờ chồng lấn 1', +      daysOfWeek: [1, 2], // Thứ 2, Thứ 3 +      startTime: '16:00', +      endTime: '18:00', +      price: 200000, +      priority: 2, +    }, +    { +      id: 'rule-4', +      name: 'Cuối tuần', +      daysOfWeek: [6, 7], // T7, CN +      startTime: '08:00', +      endTime: '22:00', +      price: 300000, +      priority: 1, +    }, +    { +      id: 'rule-5', +      name: 'Lớp học cuối tuần', +      daysOfWeek: [6], // T7 +      startTime: '09:00', +      endTime: '11:00', +      price: 280000, +      priority: 2, +    } +  ]; + +  it('identifies rules that do not overlap', () => { +    const rules = [sampleRules[0], sampleRules[1], sampleRules[3]]; +    expect(checkPricingRulesOverlap(rules)).toEqual([]); +  }); + +  it('detects partial overlay on the same day', () => { +    const rules = [sampleRules[0], sampleRules[2]]; +    expect(checkPricingRulesOverlap(rules)).toEqual( +      expect.arrayContaining(['rule-1', 'rule-3']) +    ); +  }); + +  it('detects sub-interval overlap', () => { +    const rules = [sampleRules[3], sampleRules[4]]; +    expect(checkPricingRulesOverlap(rules)).toEqual( +      expect.arrayContaining(['rule-4', 'rule-5']) +    ); +  }); + +  it('handles multiple overlapping rules across different days', () => { +    const overlapping = checkPricingRulesOverlap(sampleRules); +    expect(overlapping.sort()).toEqual(['rule-1', 'rule-2', 'rule-3', 'rule-4', 'rule-5'].sort()); +  }); + +  it('returns empty array when input is empty or has single rule', () => { +    expect(checkPricingRulesOverlap([])).toEqual([]); +    expect(checkPricingRulesOverlap([sampleRules[0]])).toEqual([]); +  }); +});
