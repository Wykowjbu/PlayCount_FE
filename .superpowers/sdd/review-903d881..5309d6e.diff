+            </div>
+          </div>
+        ) : (
+          <div className="mx-auto h-8 w-8 rounded-full bg-[var(--pc-green-800)] text-white flex items-center justify-center font-bold text-xs" title="PlayCourt Pro">
+            PC
+          </div>
+        )}
+      </div>
+
+    </aside>
+  );
+}
